{
    "layout": {
        "type": "grid",
        "rows": 2,
        "cols": 2,
        "space": "2.4mm",
        "renamenet": "Board_{n}-{orig}",
        "renameref": "{orig}"
    },
    "source": {
        "type": "auto",
        "tolerance": "50mm"
    },
    "tabs": {
        "type": "fixed",
        "hwidth": "45mm",
        "vwidth": "65mm"
    },
    "cuts": {
        "type": "vcuts",
        "offset": "-0.2mm",
        "clearance": "0.8mm"
    },
    "framing": {
        "type": "frame",
        "width": "8mm"
    },
    "post": {
        "type": "auto",
        "millradius": "1mm",
        "refillzones": true
    },
    "copperfill": {
        "type": "hatched",
        "width": "0.5mm",
        "spacing": "1mm",
        "orientation": "0deg",
        "layers": "F.Cu,B.Cu",
        "clearance": "1mm"
    },
    "fiducials": {
        "type": "3fid",
        "hoffset": "8mm",
        "voffset": "4mm",
        "coppersize": "2mm",
        "opening": "2.5mm",
        "paste": true
    },
    "tooling": {
        "type": "4hole",
        "hoffset": "4mm",
        "voffset": "4mm",
        "size": "2.5mm",
        "paste": true
    }
}