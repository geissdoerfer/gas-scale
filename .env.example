# ===== PostgreSQL Database =====
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=duoclean
POSTGRES_USER=duoclean_user
POSTGRES_PASSWORD=change_this_secure_password

# ===== MQTT Broker =====
# Use host.docker.internal to access host's localhost from Docker
MQTT_BROKER_HOST=host.docker.internal
MQTT_BROKER_PORT=1883
MQTT_TOPIC=sensors/+/data
MQTT_CLIENT_ID=duoclean-ingestor
MQTT_QOS=1
MQTT_KEEPALIVE=60

# Optional MQTT authentication (MVP: not used)
MQTT_USERNAME=
MQTT_PASSWORD=

# ===== Web API (Future) =====
JWT_SECRET=change_this_to_random_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS origins (comma-separated)
API_CORS_ORIGINS=http://localhost:3000,http://localhost

# ===== Database Connection Pool =====
DB_POOL_MIN=2
DB_POOL_MAX=10

# ===== Logging =====
LOG_LEVEL=INFO

# ===== Frontend (Future) =====
VUE_APP_API_URL=http://localhost:8000
